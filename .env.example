# LotsTracker — Configurazione ambiente produzione
# ================================================
# 1. Rinominare questo file in .env
# 2. Impostare tutti i valori indicati sotto
# 3. Non condividere mai il file .env — contiene dati sensibili

# --- Immagine Docker ---
# Percorso completo dell'immagine su GitHub Container Registry.
# Sostituire con il valore fornito dal team di sviluppo.
# Formato: ghcr.io/GITHUB_USERNAME/NOME_REPOSITORY
IMAGE_NAME=ghcr.io/GITHUB_USERNAME/lotsTracker

# Tag della versione da usare (latest = sempre l'ultima)
IMAGE_TAG=latest

# --- Sicurezza Django ---
# Chiave segreta — OBBLIGATORIO CAMBIARE con un valore casuale lungo.
# Generare con: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=CAMBIA_QUESTA_CHIAVE_CON_VALORE_CASUALE_SICURO

# --- Rete ---
# Hostname/ indirizzi IP autorizzati, separati da virgola.
# Es: ALLOWED_HOSTS=192.168.1.100,lotstracker.azienda.local
# Lasciare * solo per ambienti interni senza accesso a internet
ALLOWED_HOSTS=*
